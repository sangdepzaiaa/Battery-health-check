<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_round_24"
    android:padding="16dp">

    <!-- Tiêu đề -->
    <TextView
        android:id="@+id/txvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/select_Days_Interval"
        android:fontFamily="@font/font_inter_semi_bold"
        android:textSize="16sp"
        android:textColor="@color/color_37C186"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp"/>

    <FrameLayout
        android:id="@+id/pickerContainer"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/txvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- fade top -->
        <View
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_gravity="top"
            android:background="@drawable/bg_picker_fade_top"/>

        <!-- fade bottom -->
        <View
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_picker_fade_bottom"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_picker_highlight"/>

        <LinearLayout
            android:id="@+id/ll"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:gravity="center"
            android:orientation="horizontal">

            <NumberPicker
                android:id="@+id/txvHour"
                android:theme="@style/NumberPickerTheme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=":"
                android:textSize="20sp"
                android:textColor="@color/black"
                android:layout_marginHorizontal="8dp"/>

            <NumberPicker
                android:id="@+id/txvMinute"
                android:theme="@style/NumberPickerTheme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </FrameLayout>

    <!-- Nút bấm -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSetInterval"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/set_Days_Interval"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="@font/font_inter_medium"
        android:background="@drawable/bg_round_8"
        app:layout_constraintTop_toBottomOf="@id/pickerContainer"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
