<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_round_16">

    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:id="@+id/vProgramer"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/imgProgrammer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/ic_programmer"
        app:layout_constraintStart_toStartOf="@+id/vProgramer"
        app:layout_constraintTop_toTopOf="@+id/vProgramer" />

    <TextView
        android:id="@+id/txvName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/font_inter_semi_bold"
        android:gravity="center_vertical"
        android:text="@string/programmer"
        android:textColor="@color/color_37474F"
        android:textSize="16dp"
        app:layout_constraintBottom_toBottomOf="@+id/imgProgrammer"
        app:layout_constraintStart_toEndOf="@+id/imgProgrammer"
        app:layout_constraintTop_toTopOf="@+id/vProgrammer" />

    <com.example.myapplication.IOSSwitch
        android:id="@+id/customSwitch"
        app:layout_constraintTop_toTopOf="@+id/vProgramer"
        app:layout_constraintEnd_toEndOf="@+id/vProgramer"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:id="@+id/vContent"
        app:layout_constraintTop_toBottomOf="@+id/vProgramer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txvSetTimeAndInterval"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/font_inter_regular"
        android:gravity="center_vertical"
        android:text="@string/text_set_time_and_interval"
        android:textColor="@color/color_37474F"
        android:textSize="14dp"
        app:layout_constraintTop_toBottomOf="@+id/txvName"
        app:layout_constraintStart_toStartOf="@+id/vProgramer"
        />
    
    <TextView
        android:id="@+id/txvSetTime"
        android:layout_width="144dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/font_inter_semi_bold"
        android:textSize="14sp"
        android:textColor="@color/color_607D8B"
        app:layout_constraintTop_toTopOf="@+id/vContent"
        app:layout_constraintStart_toStartOf="@+id/vContent"
        android:layout_marginStart="12dp"
        android:layout_marginTop="16dp"
        android:text="@string/set_time"/>

    <androidx.appcompat.widget.AppCompatButton
        android:layout_width="144dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_round_8"
        app:layout_constraintTop_toBottomOf="@+id/txvSetTime"
        app:layout_constraintStart_toStartOf="@+id/vProgramer"
        android:layout_marginStart="12dp"
        android:text="@string/text_set_time"
        android:fontFamily="@font/font_inter_medium"
        android:drawableEnd="@drawable/ic_set"
        android:textSize="12sp"
        android:paddingStart="6dp"
        android:gravity="center_vertical|start"
        android:textColor="@color/white"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/txvSetInterval"
        android:layout_width="144dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/font_inter_semi_bold"
        android:textSize="14sp"
        android:textColor="@color/color_607D8B"
        app:layout_constraintTop_toTopOf="@+id/vContent"
        android:layout_marginEnd="12dp"
        app:layout_constraintEnd_toEndOf="@+id/vContent"
        android:layout_marginStart="12dp"
        android:layout_marginTop="16dp"
        android:text="@string/set_interval"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSetInterval"
        android:layout_width="144dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_round_8"
        app:layout_constraintTop_toBottomOf="@+id/txvSetInterval"
        app:layout_constraintEnd_toEndOf="@+id/vContent"
        android:layout_marginEnd="12dp"
        android:text="@string/text_set_time"
        android:fontFamily="@font/font_inter_medium"
        android:drawableEnd="@drawable/ic_set"
        android:textSize="12sp"
        android:paddingStart="6dp"
        android:gravity="center_vertical|start"
        android:textColor="@color/white"
        android:layout_marginTop="8dp"/>

    <ImageView
        android:id="@+id/imgInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_info"
        app:layout_constraintTop_toBottomOf="@+id/vContent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginStart="12dp"/>

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/txvContent"
        app:layout_constraintTop_toBottomOf="@+id/vContent"
        app:layout_constraintStart_toEndOf="@+id/imgInfo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="12dp"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/font_inter_italic"
        android:textSize="12sp"
        android:textColor="@color/color_607D8B"
        android:text="@string/text_content"/>



</androidx.constraintlayout.widget.ConstraintLayout>