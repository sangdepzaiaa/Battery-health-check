<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_round_24"
    android:padding="16dp"
    android:layout_height="wrap_content">

    <!-- Tiêu đề -->
    <TextView
        android:id="@+id/txvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/select_Days_Interval"
        android:fontFamily="@font/font_inter_semi_bold"
        android:textSize="16sp"
        android:textColor="@color/color_37C186"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerDays"
        android:layout_marginVertical="10dp"
        app:layout_constraintTop_toBottomOf="@+id/txvTitle"
        app:layout_constraintBottom_toTopOf="@+id/btnSetInterval"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSetInterval"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/set_Days_Interval"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="@font/font_inter_medium"
        android:background="@drawable/bg_round_8"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>